rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'Cecav74Yr8MRcniXuD0ky5Xe9LE3' ||
        request.auth.uid == 'ejZpXifCabUzw9ZxhRRWZVzFmpo2'
      );
    }

    // Users can read/write their own profile. Admins can write any profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());

      // Sub-collections under user (taskCompletions, delegationEvents, stats)
      match /{subcollection}/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    // Stores — any authenticated user can read, only admins can write
    match /stores/{storeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Districts — any authenticated user can read, only admins can write
    match /districts/{districtId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // District collection — any authenticated user can read, users write their own summary
    match /district/{period}/{date}/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
